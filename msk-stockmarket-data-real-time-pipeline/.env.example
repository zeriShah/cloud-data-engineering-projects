# Copy this file to .env and fill in your actual values
# NEVER commit .env to git

# ─── AWS ────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# MSK Bootstrap string (IAM / port 9098) — get from:
# MSK → kafka-msk-cluster → View client information → IAM row
BOOTSTRAP=b-1.kafkamskcluster.xxxxxx.c10.kafka.us-east-1.amazonaws.com:9098,b-2.kafkamskcluster.xxxxxx.c10.kafka.us-east-1.amazonaws.com:9098

# ─── EC2 ────────────────────────────────────────────────
PUB_EC2_PUBLIC_IP=54.x.x.x
PRT_EC2_PRIVATE_IP=10.0.3.x

# ─── S3 ─────────────────────────────────────────────────
S3_BUCKET_NAME=kafka-msk-snowflake-bucket

# ─── Snowflake ───────────────────────────────────────────
# From DESC INTEGRATION s3_kafka_integration;
SNOWFLAKE_IAM_USER_ARN=arn:aws:iam::XXXX:user/XXXX
SNOWFLAKE_EXTERNAL_ID=XXXX_SFCRole=XXXX
